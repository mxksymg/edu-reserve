<!-- ============================================================== -->
<!-- MOJE KURSY -->
<!-- ============================================================== -->

<div style="margin-bottom: 28px;">
  <h1 style="font-size: 28px; font-weight: 700; color: #0f172a; margin-bottom: 4px; letter-spacing: -0.5px;">
    📚 Moje kursy
  </h1>
  <p style="color: #64748b; font-size: 16px;">
    Kursy, które prowadzisz
  </p>
</div>

<!-- Przycisk dodawania -->
<div style="margin-bottom: 20px;">
  <%= link_to "➕ Nowy kurs", new_teacher_course_path, style: "display: inline-block; padding: 10px 20px; background: #6366f1; color: white; border-radius: 10px; text-decoration: none; font-weight: 500; transition: all 0.2s ease;" %>
</div>

<!-- Lista kursów -->
<div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px;">
  <% @courses.each do |course| %>
    <div style="background: white; border-radius: 16px; padding: 24px; box-shadow: 0 4px 20px rgba(0,0,0,0.06); border: 1px solid #f1f5f9; transition: all 0.2s ease;">
      <div style="display: flex; justify-content: space-between; align-items: flex-start;">
        <div>
          <h3 style="font-size: 18px; font-weight: 600; color: #0f172a; margin: 0;"><%= course.name %></h3>
          <div style="display: flex; gap: 8px; margin-top: 6px;">
            <span style="display: inline-block; padding: 2px 10px; border-radius: 9999px; background: #eef2ff; font-size: 11px; font-weight: 500; color: #6366f1;">
              <%= course.level&.capitalize || 'Brak poziomu' %>
            </span>
            <span style="display: inline-block; padding: 2px 10px; border-radius: 9999px; background: #f1f5f9; font-size: 11px; font-weight: 500; color: #64748b;">
              <%= course.price || 0 %> zł
            </span>
          </div>
        </div>
        <div style="font-size: 12px; color: #94a3b8;">
          <%= course.reservations.count %> rezerwacji
        </div>
      </div>
      
      <p style="color: #64748b; font-size: 14px; margin-top: 12px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
        <%= course.description || 'Brak opisu' %>
      </p>
      
      <div style="display: flex; gap: 8px; margin-top: 16px; padding-top: 16px; border-top: 1px solid #f1f5f9;">
        <%= link_to "Zobacz", teacher_course_path(course), style: "flex: 1; text-align: center; padding: 8px; background: #6366f1; color: white; border-radius: 8px; text-decoration: none; font-size: 14px; font-weight: 500;" %>
        <%= link_to "Edytuj", edit_teacher_course_path(course), style: "flex: 1; text-align: center; padding: 8px; background: #f1f5f9; color: #64748b; border-radius: 8px; text-decoration: none; font-size: 14px; font-weight: 500;" %>
        <%= button_to "Usuń", teacher_course_path(course), method: :delete, style: "flex: 1; text-align: center; padding: 8px; background: #fee2e2; color: #991b1b; border: none; border-radius: 8px; cursor: pointer; font-size: 14px; font-weight: 500;", data: { confirm: "Na pewno chcesz usunąć ten kurs?" } %>
      </div>
    </div>
  <% end %>
</div>