<!-- ============================================================== -->
<!-- SZCZEGÓŁY KURSU (NAUCZYCIEL) -->
<!-- ============================================================== -->

<div style="max-width: 900px; margin: 0 auto;">
  
  <a href="<%= teacher_courses_path %>" style="display: inline-flex; align-items: center; gap: 6px; color: #6366f1; text-decoration: none; font-size: 14px; font-weight: 500; margin-bottom: 20px;">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 18px; height: 18px;">
      <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
    </svg>
    Powrót do listy kursów
  </a>

  <div style="background: white; border-radius: 16px; padding: 28px; box-shadow: 0 4px 20px rgba(0,0,0,0.06);">
    
    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20px;">
      <div style="flex: 1; min-width: 0;">
        <!-- ✅ NAZWA KURSU - Z ZAWIJANIEM -->
        <h1 style="font-size: 28px; font-weight: 700; color: #0f172a; margin: 0; word-wrap: break-word; overflow-wrap: break-word; word-break: break-word;">
          <%= @course.name %>
        </h1>
        <div style="display: flex; flex-wrap: wrap; gap: 12px; margin-top: 8px;">
          <span style="display: inline-block; padding: 2px 12px; border-radius: 9999px; background: #eef2ff; font-size: 13px; font-weight: 500; color: #6366f1;">
            <%= @course.level&.capitalize || 'Brak poziomu' %>
          </span>
          <span style="display: inline-block; padding: 2px 12px; border-radius: 9999px; background: #f1f5f9; font-size: 13px; font-weight: 500; color: #64748b;">
            <%= @course.category&.capitalize || 'Brak kategorii' %>
          </span>
          <span style="display: inline-block; padding: 2px 12px; border-radius: 9999px; background: #dcfce7; font-size: 13px; font-weight: 500; color: #166534;">
            <%= @course.price || 0 %> zł
          </span>
        </div>
      </div>
      <div style="display: flex; gap: 8px; flex-shrink: 0; margin-left: 16px;">
        <%= link_to "✏️ Edytuj", edit_teacher_course_path(@course), style: "padding: 8px 16px; background: #f1f5f9; color: #64748b; border-radius: 8px; text-decoration: none; font-size: 14px; font-weight: 500;" %>
        <%= button_to "🗑️ Usuń", teacher_course_path(@course), method: :delete, style: "padding: 8px 16px; background: #fee2e2; color: #991b1b; border: none; border-radius: 8px; cursor: pointer; font-size: 14px; font-weight: 500;", data: { confirm: "Na pewno chcesz usunąć ten kurs?" } %>
      </div>
    </div>

    <!-- ✅ OPIS - Z ZAWIJANIEM -->
    <div style="background: #f8fafc; border-radius: 12px; padding: 20px; margin-bottom: 20px;">
      <h3 style="font-size: 16px; font-weight: 600; color: #0f172a; margin-bottom: 8px;">📖 Opis</h3>
      <p style="
        color: #475569; 
        font-size: 15px; 
        line-height: 1.8;
        margin: 0;
        word-wrap: break-word;
        overflow-wrap: break-word;
        white-space: normal;
        word-break: break-word;
      ">
        <%= @course.description || 'Brak opisu' %>
      </p>
    </div>

    <!-- Szczegóły -->
    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; margin-bottom: 20px;">
      <div style="background: #f8fafc; border-radius: 10px; padding: 14px; text-align: center;">
        <div style="font-size: 12px; color: #94a3b8;">Czas trwania</div>
        <div style="font-size: 18px; font-weight: 600; color: #0f172a;"><%= @course.duration || '?' %> h</div>
      </div>
      <div style="background: #f8fafc; border-radius: 10px; padding: 14px; text-align: center;">
        <div style="font-size: 12px; color: #94a3b8;">Max studentów</div>
        <div style="font-size: 18px; font-weight: 600; color: #0f172a;"><%= @course.max_students || '∞' %></div>
      </div>
      <div style="background: #f8fafc; border-radius: 10px; padding: 14px; text-align: center;">
        <div style="font-size: 12px; color: #94a3b8;">Rezerwacje</div>
        <div style="font-size: 18px; font-weight: 600; color: #0f172a;"><%= @course.reservations.count %></div>
      </div>
    </div>

    <!-- ✅ TERMINY - Z ZAWIJANIEM -->
    <h3 style="font-size: 16px; font-weight: 600; color: #0f172a; margin-bottom: 12px;">📅 Terminy</h3>
    <% if @schedules.any? %>
      <div style="display: flex; flex-direction: column; gap: 8px;">
        <% @schedules.each do |schedule| %>
          <div style="background: #f8fafc; border-radius: 10px; padding: 14px 18px; display: flex; justify-content: space-between; align-items: center; border-left: 4px solid #6366f1; flex-wrap: wrap; gap: 8px;">
            <div style="flex: 1; min-width: 0;">
              <div style="font-weight: 500; color: #0f172a; word-wrap: break-word; overflow-wrap: break-word; word-break: break-word;">
                <%= schedule.weekday_name %>
              </div>
              <div style="font-size: 13px; color: #64748b; margin-top: 2px; word-wrap: break-word; overflow-wrap: break-word; word-break: break-word;">
                🕐 <%= schedule.start_time.strftime("%H:%M") %> - <%= schedule.end_time.strftime("%H:%M") %>
                🏫 <%= schedule.room || 'Brak sali' %>
              </div>
            </div>
            <div style="font-size: 13px; color: #94a3b8; flex-shrink: 0;">
              👥 <%= schedule.reservations.count %> studentów
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p style="color: #94a3b8; text-align: center; padding: 20px 0;">Brak terminów</p>
    <% end %>

    <div style="margin-top: 20px; padding-top: 20px; border-top: 1px solid #f1f5f9;">
      <%= link_to "🔙 Powrót", teacher_courses_path, style: "color: #64748b; text-decoration: none; font-size: 14px;" %>
    </div>
  </div>
</div>