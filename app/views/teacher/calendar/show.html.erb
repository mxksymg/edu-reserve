<!-- ============================================================== -->
<!-- SZCZEGÓŁY ZAJĘĆ -->
<!-- ============================================================== -->

<div style="max-width: 800px; margin: 0 auto;">
  
  <!-- Nawigacja powrotna -->
  <a href="<%= teacher_calendar_path %>" style="display: inline-flex; align-items: center; gap: 6px; color: #6366f1; text-decoration: none; font-size: 14px; font-weight: 500; margin-bottom: 20px; transition: all 0.2s ease;">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 18px; height: 18px;">
      <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
    </svg>
    Powrót do kalendarza
  </a>

  <!-- Karta szczegółów -->
  <div style="background: white; border-radius: 16px; padding: 28px; box-shadow: 0 4px 20px rgba(0,0,0,0.06);">
    
    <!-- Nagłówek -->
    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20px;">
      <div>
        <h1 style="font-size: 24px; font-weight: 700; color: #0f172a; margin-bottom: 4px;">
          <%= @schedule.course.name %>
        </h1>
        <div style="display: flex; align-items: center; gap: 16px; font-size: 14px; color: #64748b;">
          <span>📅 <%= @schedule.weekday_name %></span>
          <span>🕐 <%= @schedule.start_time.strftime("%H:%M") %> - <%= @schedule.end_time.strftime("%H:%M") %></span>
          <span>🏫 <%= @schedule.room || 'Brak sali' %></span>
        </div>
      </div>
      <span style="display: inline-block; padding: 4px 16px; border-radius: 9999px; background: #eef2ff; color: #6366f1; font-size: 13px; font-weight: 500;">
        <%= @schedule.reservations.count %> studentów
      </span>
    </div>

    <!-- Statystyki -->
    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; margin-bottom: 24px;">
      <div style="background: #f8fafc; border-radius: 10px; padding: 14px 16px; text-align: center;">
        <div style="font-size: 22px; font-weight: 700; color: #0f172a;"><%= @reservations.count %></div>
        <div style="font-size: 13px; color: #64748b;">Wszystkich</div>
      </div>
      <div style="background: #dcfce7; border-radius: 10px; padding: 14px 16px; text-align: center;">
        <div style="font-size: 22px; font-weight: 700; color: #166534;"><%= @confirmed.count %></div>
        <div style="font-size: 13px; color: #166534;">Potwierdzonych</div>
      </div>
      <div style="background: #fef3c7; border-radius: 10px; padding: 14px 16px; text-align: center;">
        <div style="font-size: 22px; font-weight: 700; color: #92400e;"><%= @pending.count %></div>
        <div style="font-size: 13px; color: #92400e;">Oczekujących</div>
      </div>
    </div>

    <!-- Lista studentów -->
    <h3 style="font-size: 16px; font-weight: 600; color: #0f172a; margin-bottom: 12px;">👥 Lista studentów</h3>
    
    <% if @reservations.any? %>
      <div style="border: 1px solid #f1f5f9; border-radius: 10px; overflow: hidden;">
        <table style="width: 100%; border-collapse: collapse;">
          <thead style="background: #f8fafc;">
            <tr>
              <th style="padding: 10px 16px; text-align: left; font-size: 12px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px;">Student</th>
              <th style="padding: 10px 16px; text-align: center; font-size: 12px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px;">Status</th>
              <th style="padding: 10px 16px; text-align: right; font-size: 12px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px;">Akcje</th>
            </tr>
          </thead>
          <tbody>
            <% @reservations.each do |res| %>
              <tr style="border-top: 1px solid #f1f5f9;">
                <td style="padding: 10px 16px;">
                  <div style="font-weight: 500; color: #0f172a;"><%= res.user.first_name %> <%= res.user.last_name %></div>
                  <div style="font-size: 13px; color: #64748b;"><%= res.user.email %></div>
                </td>
                <td style="padding: 10px 16px; text-align: center;">
                  <span style="display: inline-flex; align-items: center; padding: 4px 12px; border-radius: 9999px; font-size: 12px; font-weight: 500; background: <%= res.status == 'confirmed' ? '#dcfce7' : res.status == 'pending' ? '#fef3c7' : '#fee2e2' %>; color: <%= res.status == 'confirmed' ? '#166534' : res.status == 'pending' ? '#92400e' : '#991b1b' %>;">
                    <%= res.status == 'confirmed' ? '✅ Potwierdzona' : res.status == 'pending' ? '⏳ Oczekuje' : '❌ Anulowana' %>
                  </span>
                </td>
                <td style="padding: 10px 16px; text-align: right;">
                  <% if res.pending? %>
                    <%= button_to "✅ Potwierdź", confirm_teacher_reservation_path(res), method: :patch, style: "background: #22c55e; color: white; border: none; padding: 4px 12px; border-radius: 6px; cursor: pointer; font-size: 12px; font-weight: 500;" %>
                  <% elsif res.confirmed? %>
                    <%= button_to "❌ Anuluj", cancel_teacher_reservation_path(res), method: :patch, style: "background: #ef4444; color: white; border: none; padding: 4px 12px; border-radius: 6px; cursor: pointer; font-size: 12px; font-weight: 500;" %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p style="color: #94a3b8; text-align: center; padding: 32px 0;">Brak studentów na tych zajęciach</p>
    <% end %>
  </div>
</div>