<!DOCTYPE html>
<html>
<head>
  <title>EduReserve - Logowanie</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: linear-gradient(180deg, #f8fafc 0%, #eef2ff 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
      color: #0f172a;
    }
    
    .auth-container {
      background: white;
      padding: 40px 36px;
      border-radius: 20px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.06);
      width: 100%;
      max-width: 400px;
    }
    
    .auth-header {
      text-align: center;
      margin-bottom: 32px;
    }
    
    .auth-header .icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 56px;
      height: 56px;
      background: #eef2ff;
      border-radius: 14px;
      margin-bottom: 16px;
    }
    
    .auth-header .icon svg {
      width: 32px;
      height: 32px;
      color: #6366f1;
    }
    
    .auth-header h1 {
      color: #0f172a;
      font-size: 26px;
      font-weight: 700;
      letter-spacing: -0.5px;
    }
    
    .auth-header p {
      color: #64748b;
      margin-top: 6px;
      font-size: 15px;
    }
    
    .alert {
      display: flex;
      align-items: center;
      gap: 10px;
      background: #d1fae5;
      color: #065f46;
      padding: 12px 16px;
      border-radius: 10px;
      margin-bottom: 20px;
      font-size: 14px;
    }
    
    .alert svg {
      width: 20px;
      height: 20px;
      flex-shrink: 0;
      color: #059669;
    }
    
    .alert-error {
      background: #fee2e2;
      color: #991b1b;
    }
    
    .alert-error svg {
      color: #dc2626;
    }
    
    .form-group {
      margin-bottom: 18px;
    }
    
    .form-group label {
      display: block;
      font-weight: 500;
      margin-bottom: 6px;
      color: #334155;
      font-size: 14px;
    }
    
    .input-wrapper {
      position: relative;
    }
    
    .input-wrapper .input-icon {
      position: absolute;
      left: 14px;
      top: 50%;
      transform: translateY(-50%);
      width: 18px;
      height: 18px;
      color: #94a3b8;
      pointer-events: none;
    }
    
    .form-group input {
      width: 100%;
      padding: 12px 16px 12px 44px;
      border: 2px solid #e2e8f0;
      border-radius: 10px;
      font-size: 15px;
      transition: all 0.2s ease;
      background: #f8fafc;
      color: #0f172a;
      font-family: inherit;
    }
    
    .form-group input:focus {
      outline: none;
      border-color: #6366f1;
      background: #ffffff;
      box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.12);
    }
    
    .form-group input::placeholder {
      color: #94a3b8;
    }
    
    .btn-primary {
      width: 100%;
      padding: 14px;
      background: #6366f1;
      color: white;
      border: none;
      border-radius: 10px;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s ease;
      font-family: inherit;
      margin-top: 6px;
    }
    
    .btn-primary:hover {
      background: #4f46e5;
      transform: translateY(-1px);
      box-shadow: 0 4px 16px rgba(99, 102, 241, 0.35);
    }
    
    .btn-primary:active {
      transform: translateY(0);
    }
    
    .auth-footer {
      text-align: center;
      margin-top: 24px;
      color: #64748b;
      font-size: 14px;
      padding-top: 20px;
      border-top: 1px solid #f1f5f9;
    }
    
    .auth-footer a {
      color: #6366f1;
      text-decoration: none;
      font-weight: 500;
      display: inline-flex;
      align-items: center;
      gap: 4px;
      transition: all 0.2s ease;
    }
    
    .auth-footer a:hover {
      color: #4f46e5;
      gap: 8px;
    }
    
    .auth-footer a svg {
      width: 16px;
      height: 16px;
      transition: transform 0.2s ease;
    }
    
    .auth-footer a:hover svg {
      transform: translateX(2px);
    }
  </style>
</head>
<body>
  <div class="auth-container">
    <div class="auth-header">
      <div class="icon">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" />
        </svg>
      </div>
      <h1>EduReserve</h1>
      <p>System rezerwacji zajęć</p>
    </div>
    
    <% if flash[:alert] %>
      <div class="alert alert-error">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
        </svg>
        <%= flash[:alert] %>
      </div>
    <% end %>
    
    <% if flash[:notice] %>
      <div class="alert">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <%= flash[:notice] %>
      </div>
    <% end %>
    
    <%= yield %>
    
    <div class="auth-footer">
      Nie masz konta?
      <a href="/register">
        Załóż konto
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </div>
</body>
</html>