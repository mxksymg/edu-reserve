<!DOCTYPE html>
<html>
<head>
  <title>EduReserve</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #f8fafc;
      min-height: 100vh;
      color: #0f172a;
    }
    
    /* ===== NAVBAR ===== */
    .navbar {
      background: #1e293b;
      padding: 0 32px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      height: 64px;
      border-bottom: 1px solid #334155;
      position: sticky;
      top: 0;
      z-index: 50;
    }
    
    .navbar-left {
      display: flex;
      align-items: center;
      gap: 32px;
    }
    
    .navbar-brand {
      font-size: 18px;
      font-weight: 700;
      color: white;
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    
    .navbar-brand svg {
      width: 24px;
      height: 24px;
      color: #818cf8;
    }
    
    /* Linki nawigacyjne */
    .nav-links {
      display: flex;
      align-items: center;
      gap: 4px;
    }
    
    .nav-links a {
      color: #94a3b8;
      text-decoration: none;
      font-size: 14px;
      font-weight: 500;
      padding: 8px 16px;
      border-radius: 8px;
      transition: all 0.2s ease;
    }
    
    .nav-links a:hover {
      color: #f1f5f9;
      background: rgba(255,255,255,0.06);
    }
    
    .nav-links a.active {
      color: #f1f5f9;
      background: rgba(255,255,255,0.08);
    }
    
    /* ===== ROZWIJANE MENU ===== */
    .dropdown {
      position: relative;
      display: inline-block;
    }
    
    .dropdown-toggle {
      display: flex;
      align-items: center;
      gap: 8px;
      background: transparent;
      border: none;
      color: #e2e8f0;
      cursor: pointer;
      padding: 6px 12px;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 500;
      transition: all 0.2s ease;
      font-family: inherit;
    }
    
    .dropdown-toggle:hover {
      background: rgba(255,255,255,0.06);
    }
    
    .dropdown-toggle .avatar {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: #6366f1;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-weight: 600;
      font-size: 13px;
    }
    
    .dropdown-toggle .chevron {
      width: 16px;
      height: 16px;
      color: #94a3b8;
      transition: transform 0.2s ease;
    }
    
    .dropdown-toggle .chevron.open {
      transform: rotate(180deg);
    }
    
    .dropdown-menu {
      display: none;
      position: absolute;
      right: 0;
      top: 44px;
      background: white;
      border-radius: 12px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.12);
      min-width: 180px;
      padding: 6px 0;
      border: 1px solid #f1f5f9;
    }
    
    .dropdown-menu.open {
      display: block;
    }
    
    .dropdown-menu a {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 16px;
      color: #334155;
      text-decoration: none;
      font-size: 14px;
      transition: background 0.15s ease;
    }
    
    .dropdown-menu a:hover {
      background: #f8fafc;
    }
    
    .dropdown-menu a svg {
      width: 18px;
      height: 18px;
      color: #94a3b8;
    }
    
    .dropdown-menu .divider {
      height: 1px;
      background: #f1f5f9;
      margin: 4px 12px;
    }
    
    .dropdown-menu .logout-item {
      color: #ef4444;
    }
    
    .dropdown-menu .logout-item svg {
      color: #ef4444;
    }

    .dropdown-menu .dropdown-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 16px;
      color: #334155;
      text-decoration: none;
      font-size: 14px;
      transition: background 0.15s ease;
      background: none;
      border: none;
      width: 100%;
      text-align: left;
      cursor: pointer;
      font-family: inherit;
      box-sizing: border-box;
      }

  .dropdown-menu .dropdown-item:hover {
    background: #f8fafc;
  }

  .dropdown-menu .dropdown-item svg {
    width: 18px;
    height: 18px;
    color: #94a3b8;
    flex-shrink: 0;
  }

  .dropdown-menu .dropdown-item.logout-item {
    color: #ef4444;
  }

  .dropdown-menu .dropdown-item.logout-item svg {
    color: #ef4444;
  }

  .dropdown-menu .dropdown-item.logout-item:hover {
    background: #fef2f2;
  }

  .dropdown-menu a {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 16px;
    color: #334155;
    text-decoration: none;
    font-size: 14px;
    transition: background 0.15s ease;
  }

  .dropdown-menu a:hover {
    background: #f8fafc;
  }

  .dropdown-menu a svg {
    width: 18px;
    height: 18px;
    color: #94a3b8;
    flex-shrink: 0;
  }

  .dropdown-menu .divider {
    height: 1px;
    background: #f1f5f9;
    margin: 4px 12px;
  }



    /* ===== CONTAINER ===== */
    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 24px 24px;
    }
    
    .alert, .notice {
      padding: 12px 16px;
      border-radius: 10px;
      margin-bottom: 20px;
      font-size: 14px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    

.alert, .notice {
  padding: 12px 16px;
  border-radius: 10px;
  margin-bottom: 20px;
  font-size: 14px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  animation: slideDown 0.3s ease;
  position: relative;
}

  .alert {
    background: #fee2e2;
    color: #991b1b;
    border-left: 4px solid #dc2626;
  }

  .notice {
    background: #d1fae5;
    color: #065f46;
    border-left: 4px solid #16a34a;
  }

  .alert-close {
    background: none;
    border: none;
    font-size: 20px;
    cursor: pointer;
    color: inherit;
    opacity: 0.6;
    padding: 0 4px;
    transition: all 0.2s ease;
    flex-shrink: 0;
    line-height: 1;
  }

  .alert-close:hover {
    opacity: 1;
    transform: scale(1.2);
  }

  /* Animacja pojawiania się */
  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Animacja znikan ia */
  @keyframes fadeOut {
    from {
      opacity: 1;
      transform: translateY(0);
    }
    to {
      opacity: 0;
      transform: translateY(-10px);
    }
  }

  .alert.fade-out, .notice.fade-out {
    animation: fadeOut 0.3s ease forwards;
  }
    .alert { background: #fee2e2; color: #991b1b; }
    .notice { background: #d1fae5; color: #065f46; }
  </style>
</head>
<body>
  <% if logged_in? %>
    <nav class="navbar">
      <!-- LEWA STRONA -->
      <div class="navbar-left">
        <a href="<%= root_path %>" class="navbar-brand">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" />
          </svg>
          EduReserve
        </a>
        
        <!-- LINKI NAWIGACYJNE -->
        <div class="nav-links">
          <%= link_to "Dashboard", root_path, class: current_page?(root_path) ? "active" : "" %>
          <%= link_to "Kursy", courses_path, class: current_page?(courses_path) ? "active" : "" %>
          <%= link_to "Profil", profile_path, class: current_page?(profile_path) ? "active" : "" %>
        </div>
      </div>
      
      <!-- PRAWA STRONA - ROZWIJANE MENU -->
<div class="dropdown" id="userDropdown">
  <button class="dropdown-toggle" onclick="toggleDropdown()">
    <span class="avatar"><%= current_user.first_name&.first&.upcase || "U" %></span>
    <%= current_user.first_name %>
    <svg class="chevron" id="chevronIcon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
    </svg>
  </button>
  <div class="dropdown-menu" id="dropdownMenu">
    <%= link_to profile_path, class: "dropdown-item" do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 18px; height: 18px; color: #94a3b8;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
        </svg>
        Profil
    <% end %>
    <div class="divider"></div>
    
    <!-- WYLOGOWANIE - poprawione -->
    <%= button_to logout_path, method: :delete, class: "dropdown-item logout-item" do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 18px; height: 18px;">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75" />
      </svg>
      Wyloguj
    <% end %>
  </div>
</div>
    </nav>
    
    <script>
      function toggleDropdown() {
        const menu = document.getElementById('dropdownMenu');
        const chevron = document.getElementById('chevronIcon');
        menu.classList.toggle('open');
        chevron.classList.toggle('open');
      }
      
      // Zamknij dropdown po kliknięciu poza nim
      document.addEventListener('click', function(event) {
        const dropdown = document.getElementById('userDropdown');
        if (!dropdown.contains(event.target)) {
          document.getElementById('dropdownMenu').classList.remove('open');
          document.getElementById('chevronIcon').classList.remove('open');
        }
      });
    </script>
  <% end %>
  
  <div class="container">
    <% if flash[:alert] %>
    <div class="alert" id="alert-message">
      <span><%= flash[:alert] %></span>
      <button class="alert-close" onclick="closeAlert('alert-message')">&times;</button>
    </div>
    <% end %>

    <% if flash[:notice] %>
      <div class="notice" id="notice-message">
        <span><%= flash[:notice] %></span>
        <button class="alert-close" onclick="closeAlert('notice-message')">&times;</button>
      </div>
    <% end %>
    
    <%= yield %>
    <script>
      function closeAlert(id) {
        const element = document.getElementById(id);
        if (element) {
          element.classList.add('fade-out');
          setTimeout(() => {
            element.style.display = 'none';
          }, 300);
        }
      }

      function autoCloseAlerts() {
        const alerts = document.querySelectorAll('.alert, .notice');
        alerts.forEach((alert) => {
          setTimeout(() => {
            const id = alert.id;
            if (id) {
              closeAlert(id);
            }
          }, 5000);
        });
      }

      document.addEventListener('DOMContentLoaded', function() {
        autoCloseAlerts();
      });
    </script>

  </div>
</body>
</html>