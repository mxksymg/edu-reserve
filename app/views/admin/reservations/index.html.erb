<!-- ============================================================== -->
<!-- ADMIN - LISTA REZERWACJI -->
<!-- ============================================================== -->

<!-- ===== NAGŁÓWEK NA GÓRZE ===== -->
<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 28px;">
  <div>
    <h1 style="font-size: 28px; font-weight: 700; color: #0f172a; margin-bottom: 4px; letter-spacing: -0.5px;">
      📝 Rezerwacje
    </h1>
    <p style="color: #64748b; font-size: 16px;">
      Zarządzaj wszystkimi rezerwacjami w systemie
    </p>
  </div>
  <div style="font-size: 14px; color: #64748b; background: #f1f5f9; padding: 6px 16px; border-radius: 9999px;">
    <%= @reservations.total_entries %> rezerwacji
  </div>
</div>

<!-- ===== FILTRY ===== -->
<div style="background: white; border-radius: 12px; padding: 20px 24px; box-shadow: 0 4px 20px rgba(0,0,0,0.06); margin-bottom: 20px;">
  
  <form method="get" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; align-items: end;">
    
    <!-- Status -->
    <div>
      <label style="display: block; font-size: 13px; font-weight: 500; color: #64748b; margin-bottom: 4px;">Status</label>
      <select name="status" style="width: 100%; padding: 8px 12px; border: 2px solid #e2e8f0; border-radius: 8px; background: #f8fafc; font-size: 14px;">
        <option value="">Wszystkie</option>
        <option value="pending" <%= 'selected' if params[:status] == 'pending' %>>⏳ Oczekujące</option>
        <option value="confirmed" <%= 'selected' if params[:status] == 'confirmed' %>>✅ Potwierdzone</option>
        <option value="cancelled" <%= 'selected' if params[:status] == 'cancelled' %>>❌ Anulowane</option>
      </select>
    </div>

    <!-- Kurs - select -->
    <div>
      <label style="display: block; font-size: 13px; font-weight: 500; color: #64748b; margin-bottom: 4px;">Kurs</label>
      <select name="course_id" style="width: 100%; padding: 8px 12px; border: 2px solid #e2e8f0; border-radius: 8px; background: #f8fafc; font-size: 14px;">
        <option value="">Wszystkie</option>
        <% Course.all.each do |course| %>
          <option value="<%= course.id %>" <%= 'selected' if params[:course_id] == course.id.to_s %>>
            <%= course.name %>
          </option>
        <% end %>
      </select>
    </div>

    <!-- Użytkownik - SEARCH BAR (zamiast selecta) -->
    <div>
      <label style="display: block; font-size: 13px; font-weight: 500; color: #64748b; margin-bottom: 4px;">Użytkownik (email)</label>
      <input type="text" 
             name="user_email" 
             value="<%= params[:user_email] %>" 
             placeholder="Szukaj po emailu..."
             style="width: 100%; padding: 8px 12px; border: 2px solid #e2e8f0; border-radius: 8px; background: #f8fafc; font-size: 14px; transition: all 0.2s ease;"
             onfocus="this.style.borderColor='#6366f1'; this.style.boxShadow='0 0 0 4px rgba(99,102,241,0.1)';"
             onblur="this.style.borderColor='#e2e8f0'; this.style.boxShadow='none';">
    </div>

    <!-- Przyciski -->
    <div style="display: flex; gap: 8px;">
      <button type="submit" style="padding: 8px 20px; background: #6366f1; color: white; border: none; border-radius: 8px; cursor: pointer; font-weight: 500; font-size: 14px; transition: all 0.2s ease; hover:background: #4f46e5;">
        🔍 Filtruj
      </button>
      
      <%= link_to "Reset", admin_reservations_path, style: "padding: 8px 16px; background: #f1f5f9; color: #64748b; border-radius: 8px; text-decoration: none; font-size: 14px; font-weight: 500; transition: all 0.2s ease; hover:background: #e2e8f0;" %>
    </div>
  </form>
</div>

<!-- ===== LISTA REZERWACJI ===== -->
<div style="background: white; border-radius: 16px; padding: 24px; box-shadow: 0 4px 20px rgba(0,0,0,0.06); overflow-x: auto;">
  
  <% if @reservations.any? %>
    <table style="width: 100%; border-collapse: collapse; min-width: 800px;">
      <thead>
        <tr style="background: #f8fafc; border-bottom: 2px solid #e2e8f0;">
          <th style="padding: 12px 16px; text-align: left; font-size: 12px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px;">Użytkownik</th>
          <th style="padding: 12px 16px; text-align: left; font-size: 12px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px;">Kurs</th>
          <th style="padding: 12px 16px; text-align: center; font-size: 12px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px;">Termin</th>
          <th style="padding: 12px 16px; text-align: center; font-size: 12px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px;">Status</th>
          <th style="padding: 12px 16px; text-align: center; font-size: 12px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px;">Data</th>
          <th style="padding: 12px 16px; text-align: center; font-size: 12px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px;">Akcje</th>
        </tr>
      </thead>
      <tbody>
        <% @reservations.each do |res| %>
          <tr style="border-bottom: 1px solid #f1f5f9; hover:background: #f8fafc;">
            <td style="padding: 12px 16px;">
              <div style="font-weight: 500; color: #0f172a;"><%= res.user.first_name %> <%= res.user.last_name %></div>
              <div style="font-size: 13px; color: #64748b;"><%= res.user.email %></div>
            </td>
            <td style="padding: 12px 16px;">
              <div style="font-weight: 500; color: #0f172a;"><%= res.schedule.course.name %></div>
              <div style="font-size: 13px; color: #64748b;">Nauczyciel: <%= res.schedule.teacher&.first_name || 'Brak' %></div>
            </td>
            <td style="padding: 12px 16px; text-align: center;">
              <div style="font-size: 14px; color: #0f172a;"><%= res.schedule.weekday_name %></div>
              <div style="font-size: 13px; color: #64748b;"><%= res.schedule.start_time.strftime("%H:%M") %></div>
            </td>
            <td style="padding: 12px 16px; text-align: center;">
              <span style="display: inline-flex; align-items: center; padding: 4px 12px; border-radius: 9999px; font-size: 12px; font-weight: 500; background: <%= res.status == 'confirmed' ? '#dcfce7' : res.status == 'pending' ? '#fef3c7' : '#fee2e2' %>; color: <%= res.status == 'confirmed' ? '#166534' : res.status == 'pending' ? '#92400e' : '#991b1b' %>;">
                <%= res.status == 'confirmed' ? '✅ Potwierdzona' : res.status == 'pending' ? '⏳ Oczekuje' : '❌ Anulowana' %>
              </span>
            </td>
            <td style="padding: 12px 16px; text-align: center; font-size: 13px; color: #64748b;">
              <%= res.created_at.strftime("%d.%m.%Y %H:%M") %>
            </td>
            <td style="padding: 12px 16px; text-align: center;">
              <div style="display: flex; gap: 4px; justify-content: center; flex-wrap: wrap;">
                <%= link_to "👁️", admin_reservation_path(res), style: "padding: 4px 8px; background: #f1f5f9; color: #64748b; border-radius: 6px; text-decoration: none; font-size: 14px;" %>
                
                <% if res.pending? %>
                  <%= button_to "✅", confirm_admin_reservation_path(res), method: :patch, style: "padding: 4px 8px; background: #22c55e; color: white; border: none; border-radius: 6px; cursor: pointer; font-size: 14px;", title: "Potwierdź" %>
                <% elsif res.confirmed? %>
                  <%= button_to "❌", cancel_admin_reservation_path(res), method: :patch, style: "padding: 4px 8px; background: #ef4444; color: white; border: none; border-radius: 6px; cursor: pointer; font-size: 14px;", title: "Anuluj" %>
                <% end %>
                
                <%= button_to "🗑️", admin_reservation_path(res), method: :delete, style: "padding: 4px 8px; background: #fee2e2; color: #991b1b; border: none; border-radius: 6px; cursor: pointer; font-size: 14px;", data: { confirm: "Na pewno chcesz usunąć tę rezerwację?" } %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    
    <!-- ===== PAGINACJA ===== -->
    <div style="display: flex; justify-content: center; margin-top: 20px; padding-top: 16px; border-top: 1px solid #f1f5f9;">
      <%= will_paginate @reservations, 
          params: { status: params[:status], course_id: params[:course_id], user_email: params[:user_email] } %>
    </div>
    
  <% else %>
    <p style="text-align: center; padding: 32px 0; color: #94a3b8;">Brak rezerwacji</p>
  <% end %>
</div>