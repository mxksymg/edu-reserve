<!-- ============================================================== -->
<!-- ADMIN - PODGLĄD UŻYTKOWNIKA -->
<!-- ============================================================== -->

<div style="max-width: 700px; margin: 0 auto;">
  
  <a href="<%= admin_users_path %>" style="display: inline-flex; align-items: center; gap: 6px; color: #6366f1; text-decoration: none; font-size: 14px; font-weight: 500; margin-bottom: 20px;">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 18px; height: 18px;">
      <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
    </svg>
    Powrót do listy użytkowników
  </a>

  <div style="background: white; border-radius: 16px; padding: 28px; box-shadow: 0 4px 20px rgba(0,0,0,0.06);">
    
    <div style="display: flex; align-items: center; gap: 20px; margin-bottom: 24px;">
      <div style="width: 72px; height: 72px; border-radius: 50%; background: #6366f1; display: flex; align-items: center; justify-content: center; color: white; font-weight: 700; font-size: 28px;">
        <%= @user.first_name&.first&.upcase || "U" %>
      </div>
      <div>
        <h1 style="font-size: 24px; font-weight: 700; color: #0f172a; margin: 0;"><%= @user.first_name %> <%= @user.last_name %></h1>
        <div style="display: flex; gap: 8px; margin-top: 6px;">
          <span style="display: inline-block; padding: 2px 12px; border-radius: 9999px; font-size: 13px; font-weight: 500; background: <%= @user.role == 'admin' ? '#eef2ff' : @user.role == 'teacher' ? '#dbeafe' : '#f1f5f9' %>; color: <%= @user.role == 'admin' ? '#6366f1' : @user.role == 'teacher' ? '#2563eb' : '#64748b' %>;">
            <%= @user.role&.capitalize || 'Student' %>
          </span>
          <span style="display: inline-block; padding: 2px 12px; border-radius: 9999px; font-size: 13px; font-weight: 500; background: <%= @user.active ? '#dcfce7' : '#fee2e2' %>; color: <%= @user.active ? '#166534' : '#991b1b' %>;">
            <%= @user.active ? '✅ Aktywny' : '❌ Nieaktywny' %>
          </span>
        </div>
      </div>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
      <div style="background: #f8fafc; border-radius: 10px; padding: 16px;">
        <div style="font-size: 12px; color: #94a3b8; font-weight: 500; text-transform: uppercase; letter-spacing: 0.5px;">Email</div>
        <div style="font-size: 16px; color: #0f172a; margin-top: 4px;"><%= @user.email %></div>
      </div>
      <div style="background: #f8fafc; border-radius: 10px; padding: 16px;">
        <div style="font-size: 12px; color: #94a3b8; font-weight: 500; text-transform: uppercase; letter-spacing: 0.5px;">Dołączył</div>
        <div style="font-size: 16px; color: #0f172a; margin-top: 4px;"><%= @user.created_at.strftime("%d.%m.%Y %H:%M") %></div>
      </div>
    </div>

    <div style="display: flex; gap: 12px; margin-top: 24px; padding-top: 20px; border-top: 1px solid #f1f5f9;">
      <%= link_to "✏️ Edytuj", edit_admin_user_path(@user), style: "flex: 1; text-align: center; padding: 12px; background: #6366f1; color: white; border-radius: 10px; text-decoration: none; font-weight: 500; transition: all 0.2s ease;" %>
      <%= link_to "🔙 Powrót", admin_users_path, style: "flex: 1; text-align: center; padding: 12px; background: #f1f5f9; color: #64748b; border-radius: 10px; text-decoration: none; font-weight: 500; transition: all 0.2s ease;" %>
    </div>
  </div>
</div>