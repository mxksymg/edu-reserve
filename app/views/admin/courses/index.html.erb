<!-- ============================================================== -->
<!-- ADMIN - LISTA KURSÓW -->
<!-- ============================================================== -->

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 28px;">
  <div>
    <h1 style="font-size: 28px; font-weight: 700; color: #0f172a; margin-bottom: 4px; letter-spacing: -0.5px;">
      📚 Kursy
    </h1>
    <p style="color: #64748b; font-size: 16px;">
      Zarządzaj wszystkimi kursami w systemie
    </p>
  </div>
  <div style="display: flex; gap: 12px; align-items: center;">
    <span style="font-size: 14px; color: #64748b; background: #f1f5f9; padding: 6px 16px; border-radius: 9999px;">
      <%= @courses.total_entries %> kursów
    </span>
    <%= link_to "➕ Nowy kurs", new_admin_course_path, style: "display: inline-block; padding: 10px 20px; background: #6366f1; color: white; border-radius: 10px; text-decoration: none; font-weight: 500; transition: all 0.2s ease; hover:background: #4f46e5;" %>
  </div>
</div>

<!-- ===== FILTRY ===== -->
<div style="background: white; border-radius: 12px; padding: 20px 24px; box-shadow: 0 4px 20px rgba(0,0,0,0.06); margin-bottom: 20px;">
  
  <form method="get" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; align-items: end;">
    
    <!-- Wyszukiwanie po nazwie -->
    <div>
      <label style="display: block; font-size: 13px; font-weight: 500; color: #64748b; margin-bottom: 4px;">Szukaj</label>
      <input type="text" 
             name="search" 
             value="<%= params[:search] %>" 
             placeholder="Nazwa kursu..."
             style="width: 100%; padding: 8px 12px; border: 2px solid #e2e8f0; border-radius: 8px; background: #f8fafc; font-size: 14px; transition: all 0.2s ease;"
             onfocus="this.style.borderColor='#6366f1'; this.style.boxShadow='0 0 0 4px rgba(99,102,241,0.1)';"
             onblur="this.style.borderColor='#e2e8f0'; this.style.boxShadow='none';">
    </div>

    <!-- Poziom -->
    <div>
      <label style="display: block; font-size: 13px; font-weight: 500; color: #64748b; margin-bottom: 4px;">Poziom</label>
      <select name="level" style="width: 100%; padding: 8px 12px; border: 2px solid #e2e8f0; border-radius: 8px; background: #f8afc; font-size: 14px;">
        <option value="">Wszystkie</option>
        <option value="beginner" <%= 'selected' if params[:level] == 'beginner' %>>Beginner</option>
        <option value="intermediate" <%= 'selected' if params[:level] == 'intermediate' %>>Intermediate</option>
        <option value="advanced" <%= 'selected' if params[:level] == 'advanced' %>>Advanced</option>
      </select>
    </div>

    <!-- Kategoria -->
    <div>
      <label style="display: block; font-size: 13px; font-weight: 500; color: #64748b; margin-bottom: 4px;">Kategoria</label>
      <select name="category" style="width: 100%; padding: 8px 12px; border: 2px solid #e2e8f0; border-radius: 8px; background: #f8fafc; font-size: 14px;">
        <option value="">Wszystkie</option>
        <option value="programming" <%= 'selected' if params[:category] == 'programming' %>>Programowanie</option>
        <option value="design" <%= 'selected' if params[:category] == 'design' %>>Design</option>
        <option value="business" <%= 'selected' if params[:category] == 'business' %>>Biznes</option>
        <option value="languages" <%= 'selected' if params[:category] == 'languages' %>>Języki</option>
        <option value="marketing" <%= 'selected' if params[:category] == 'marketing' %>>Marketing</option>
      </select>
    </div>

    <!-- Przyciski -->
    <div style="display: flex; gap: 8px;">
      <button type="submit" style="padding: 8px 20px; background: #6366f1; color: white; border: none; border-radius: 8px; cursor: pointer; font-weight: 500; font-size: 14px; transition: all 0.2s ease; hover:background: #4f46e5;">
        🔍 Filtruj
      </button>
      
      <%= link_to "Reset", admin_courses_path, style: "padding: 8px 16px; background: #f1f5f9; color: #64748b; border-radius: 8px; text-decoration: none; font-size: 14px; font-weight: 500; transition: all 0.2s ease; hover:background: #e2e8f0;" %>
    </div>
  </form>
</div>

<!-- ===== LISTA KURSÓW ===== -->
<div style="background: white; border-radius: 16px; padding: 24px; box-shadow: 0 4px 20px rgba(0,0,0,0.06); overflow-x: auto;">
  
  <% if @courses.any? %>
    <table style="width: 100%; border-collapse: collapse; min-width: 800px;">
      <thead>
        <tr style="background: #f8fafc; border-bottom: 2px solid #e2e8f0;">
          <th style="padding: 12px 16px; text-align: left; font-size: 12px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px;">Nazwa</th>
          <th style="padding: 12px 16px; text-align: left; font-size: 12px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px;">Poziom</th>
          <th style="padding: 12px 16px; text-align: center; font-size: 12px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px;">Cena</th>
          <th style="padding: 12px 16px; text-align: center; font-size: 12px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px;">Nauczyciel</th>
          <th style="padding: 12px 16px; text-align: center; font-size: 12px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px;">Rezerwacje</th>
          <th style="padding: 12px 16px; text-align: center; font-size: 12px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px;">Akcje</th>
        </tr>
      </thead>
      <tbody>
        <% @courses.each do |course| %>
          <tr style="border-bottom: 1px solid #f1f5f9; hover:background: #f8fafc;">
            <td style="padding: 12px 16px;">
              <div style="font-weight: 500; color: #0f172a; word-wrap: break-word; word-break: break-word;"><%= course.name %></div>
              <div style="font-size: 12px; color: #94a3b8; word-wrap: break-word; word-break: break-word;">
                <%= course.category&.capitalize || 'Brak kategorii' %>
              </div>
            </td>
            <td style="padding: 12px 16px;">
              <span style="display: inline-block; padding: 2px 10px; border-radius: 9999px; background: #eef2ff; color: #6366f1; font-size: 12px; font-weight: 500;">
                <%= course.level&.capitalize || 'Brak' %>
              </span>
            </td>
            <td style="padding: 12px 16px; text-align: center; font-weight: 600; color: #0f172a;">
              <%= course.price || 0 %> zł
            </td>
            <td style="padding: 12px 16px; text-align: center; font-size: 13px; color: #64748b;">
              <%= course.teacher&.first_name || 'Brak' %> <%= course.teacher&.last_name || '' %>
            </td>
            <td style="padding: 12px 16px; text-align: center; font-size: 13px; color: #64748b;">
              <%= course.reservations.count %>
            </td>
            <td style="padding: 12px 16px; text-align: center;">
              <div style="display: flex; gap: 4px; justify-content: center; flex-wrap: wrap;">
                <%= link_to "👁️", admin_course_path(course), style: "padding: 4px 8px; background: #f1f5f9; color: #64748b; border-radius: 6px; text-decoration: none; font-size: 14px;" %>
                <%= link_to "✏️", edit_admin_course_path(course), style: "padding: 4px 8px; background: #f1f5f9; color: #64748b; border-radius: 6px; text-decoration: none; font-size: 14px;" %>
                <%= button_to "🗑️", admin_course_path(course), method: :delete, style: "padding: 4px 8px; background: #fee2e2; color: #991b1b; border: none; border-radius: 6px; cursor: pointer; font-size: 14px;", data: { confirm: "Na pewno chcesz usunąć ten kurs?" } %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    
    <!-- ===== PAGINACJA ===== -->
    <div style="display: flex; justify-content: center; margin-top: 20px; padding-top: 16px; border-top: 1px solid #f1f5f9;">
      <%= will_paginate @courses, 
          params: { search: params[:search], level: params[:level], category: params[:category] } %>
    </div>
    
  <% else %>
    <p style="text-align: center; padding: 32px 0; color: #94a3b8;">Brak kursów</p>
  <% end %>
</div>